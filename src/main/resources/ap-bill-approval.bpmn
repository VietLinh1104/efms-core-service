      <bpmn:outgoing>Flow_0tz6qju</bpmn:outgoing>
      <bpmn:outgoing>Flow_0ksw58a</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="checkAmout" name="approved?">
