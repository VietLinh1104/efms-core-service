      <bpmn:outgoing>Flow_185bb4k</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_085nojf" sourceRef="bill-submitted" targetRef="finance-manager-review" />
    <bpmn:sequenceFlow id="Flow_0awp6ft" sourceRef="is-fm-approval" targetRef="notify-rejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0drlygv" sourceRef="finance-manager-review" targetRef="is-fm-approval" />
    <bpmn:sequenceFlow id="Flow_0j2wzt6" sourceRef="admin-review" targetRef="is-ad-approval" />
    <bpmn:sequenceFlow id="Flow_0k2g8qt" sourceRef="checkAmout" targetRef="create-journal-entry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=totalAmount &lt;= 100000000</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0ksw58a" sourceRef="is-ad-approval" targetRef="create-journal-entry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approved = true</bpmn:conditionExpression>
