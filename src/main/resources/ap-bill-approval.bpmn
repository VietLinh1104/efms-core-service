    <bpmn:sequenceFlow id="Flow_11h5as5" sourceRef="checkAmout" targetRef="admin-review">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=totalAmount &gt; 100000000</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_185bb4k" sourceRef="create-journal-entry" targetRef="bill-approved" />
    <bpmn:sequenceFlow id="Flow_1n4474q" sourceRef="is-fm-approval" targetRef="checkAmout">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1o6ef4p" sourceRef="notify-rejection" targetRef="bill-rejected" />
    <bpmn:serviceTask id="notify-rejection" name="Notify Rejection">
